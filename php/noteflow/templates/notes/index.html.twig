{% extends 'layout/base.html.twig' %}

{% block title %}My Notes{% endblock %}

{% block content %}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
    <h1 style="font-size: 1.5rem; font-weight: 700;">My Notes</h1>
    <a href="/notes/new" class="btn btn-primary">+ New Note</a>
</div>

{# Search form #}
<form method="GET" action="/notes" style="margin-bottom: 1.5rem;">
    <input
        type="search"
        name="q"
        value="{{ query ?? '' }}"
        placeholder="Search notes..."
        style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.95rem;"
    >
</form>

{% if notes is empty %}
    <p style="color: #6b7280;">No notes yet. Create your first one!</p>
{% else %}
    <ul style="list-style: none; display: flex; flex-direction: column; gap: 1rem;">
        {% for note in notes %}
        <li style="background: #fff; border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 1rem 1.25rem;">
            <div style="display: flex; justify-content: space-between; align-items: flex-start; gap: 0.5rem;">
                <a href="/notes/{{ note.id }}" style="font-weight: 600; font-size: 1.05rem; color: #1d4ed8; text-decoration: none;">
                    {{ note.title }}
                </a>
                <span class="badge {{ note.status.badgeClass() }}">
                    {{ note.status.label() }}
                </span>
            </div>

            <p style="color: #4b5563; margin-top: 0.35rem; font-size: 0.9rem;">
                {{ note.excerpt }}{% if note.body|length > 100 %}...{% endif %}
            </p>

            {% if note.tags is not empty %}
            <div style="margin-top: 0.5rem; display: flex; flex-wrap: wrap; gap: 0.35rem;">
                {% for tag in note.tags %}
                    <span style="background: #eff6ff; color: #1d4ed8; padding: 0.1rem 0.5rem; border-radius: 9999px; font-size: 0.75rem;">
                        {{ tag }}
                    </span>
                {% endfor %}
            </div>
            {% endif %}

            <div style="margin-top: 0.75rem; display: flex; gap: 0.75rem;">
                <a href="/notes/{{ note.id }}/edit" style="font-size: 0.85rem; color: #374151;">Edit</a>
                <form method="POST" action="/notes/{{ note.id }}" style="display: inline;">
                    <input type="hidden" name="_method" value="DELETE">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token ?? '' }}">
                    <button type="submit" style="font-size: 0.85rem; color: #dc2626; background: none; border: none; cursor: pointer;"
                        onclick="return confirm('Delete this note?')">
                        Delete
                    </button>
                </form>
            </div>
        </li>
        {% endfor %}
    </ul>
{% endif %}
{% endblock %}
