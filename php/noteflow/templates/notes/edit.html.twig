{% extends 'layout/base.html.twig' %}

{% block title %}{{ note is not null ? 'Edit Note' : 'New Note' }}{% endblock %}

{% block content %}
<h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 1.5rem;">
    {{ note is not null ? 'Edit Note' : 'New Note' }}
</h1>

{% if errors is defined and errors is not empty %}
    {% for error in errors %}
        <div class="alert-error">{{ error }}</div>
    {% endfor %}
{% endif %}

<form
    method="POST"
    action="{{ action ?? '/notes' }}"
    style="display: flex; flex-direction: column; gap: 1.25rem; background: #fff; border: 1px solid #e5e7eb; border-radius: 0.5rem; padding: 1.5rem;"
>
    {# Method override for PUT (HTML forms only support GET/POST) #}
    {% if note is not null %}
        <input type="hidden" name="_method" value="PUT">
    {% endif %}

    {# CSRF token #}
    <input type="hidden" name="_csrf_token" value="{{ csrf_token ?? '' }}">

    {# Title #}
    <div>
        <label for="title" style="display: block; font-weight: 600; margin-bottom: 0.35rem;">Title</label>
        <input
            type="text"
            id="title"
            name="title"
            value="{{ note.title ?? '' }}"
            required
            style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.95rem;"
        >
    </div>

    {# Body #}
    <div>
        <label for="body" style="display: block; font-weight: 600; margin-bottom: 0.35rem;">Body</label>
        <textarea
            id="body"
            name="body"
            rows="12"
            style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.95rem; font-family: inherit; resize: vertical;"
        >{{ note.body ?? '' }}</textarea>
    </div>

    {# Tags (comma-separated) #}
    <div>
        <label for="tags" style="display: block; font-weight: 600; margin-bottom: 0.35rem;">
            Tags <span style="font-weight: 400; color: #6b7280;">(comma-separated)</span>
        </label>
        <input
            type="text"
            id="tags"
            name="tags"
            value="{{ note.tags is defined ? note.tags|join(', ') : '' }}"
            placeholder="php, learning, project"
            style="width: 100%; padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.95rem;"
        >
    </div>

    {# Status #}
    <div>
        <label for="status" style="display: block; font-weight: 600; margin-bottom: 0.35rem;">Status</label>
        <select
            id="status"
            name="status"
            style="padding: 0.5rem 0.75rem; border: 1px solid #d1d5db; border-radius: 0.375rem; font-size: 0.95rem;"
        >
            <option value="draft"     {% if note.status.value ?? 'draft' == 'draft' %}selected{% endif %}>Draft</option>
            <option value="published" {% if note.status.value ?? '' == 'published' %}selected{% endif %}>Published</option>
            <option value="archived"  {% if note.status.value ?? '' == 'archived' %}selected{% endif %}>Archived</option>
        </select>
    </div>

    {# Actions #}
    <div style="display: flex; gap: 0.75rem;">
        <button type="submit" class="btn btn-primary">
            {{ note is not null ? 'Save Changes' : 'Create Note' }}
        </button>
        <a href="/notes" style="padding: 0.45rem 1rem; color: #374151; text-decoration: none;">Cancel</a>
    </div>
</form>
{% endblock %}
