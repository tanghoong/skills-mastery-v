{
  "name": "noteflow/app",
  "description": "NoteFlow — native PHP 8.4 note-taking capstone",
  "require": {
    "php": "^8.4",
    "twig/twig": "^3.0",
    "vlucas/phpdotenv": "^5.6"
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0",
    "pestphp/pest": "^2.0"
  },
  "autoload": {
    "psr-4": { "NoteFlow\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "NoteFlow\\Tests\\": "tests/" }
  }
}
